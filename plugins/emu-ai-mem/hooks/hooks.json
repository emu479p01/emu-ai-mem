{
  "description": "Load and preserve emu-ai-mem context without storing raw transcripts.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "emu-mem hook session-start --client codex",
            "statusMessage": "Loading emu-ai-mem session",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "emu-mem hook pre-compact --client codex",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "emu-mem hook stop --client codex",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
